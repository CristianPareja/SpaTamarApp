<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainAdministrador"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorAdministrador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">
        <TextView
            android:id="@+id/txtTituloAdministrador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menú Administrador"
            android:textColor="@color/azul_titulo"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtBienvenidaAdministrador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Gestión general del Spa TAMAR"
            android:textColor="@color/gris_texto"
            android:textSize="15sp" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDashboardAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Dashboard"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClientesAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Clientes"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnServiciosAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Servicios"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCitasAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Citas"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDisponibilidadAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Disponibilidad"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProveedoresAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Proveedores"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCuentasCobrarAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Cuentas por cobrar"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCuentasPagarAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Cuentas por pagar"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIngresosAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Ingresos"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEgresosAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Egresos"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMetodosPagoAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Métodos de pago"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReportesAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Reportes"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSimulacionAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Simulación de escenarios"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProyeccionAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/boton_principal"
            android:text="Proyección de ingresos"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCerrarSesionAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/boton_principal"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="16sp"
            android:textStyle="bold" />


    </LinearLayout>

</ScrollView>