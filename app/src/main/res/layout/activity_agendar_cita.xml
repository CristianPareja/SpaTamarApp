<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="15dp"
            android:text="Agendar cita"
            android:textAlignment="center"
            android:textColor="@color/azul_titulo"
            android:textSize="25sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_login"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtClientePerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Cliente: perfil no cargado"
                android:textColor="@color/azul_titulo"
                android:textSize="15sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/chkAgendarFamiliar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Agendar cita para un familiar"
                android:textColor="@color/texto_principal"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtNombreFamiliar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del familiar"
                android:textColor="@color/azul_titulo"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <EditText
                android:id="@+id/edtNombreFamiliar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Ejemplo: Ana López"
                android:inputType="textPersonName"
                android:padding="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textColor="@color/azul_titulo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtTelefonoCliente"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Ejemplo: 0999999999"
                android:inputType="phone"
                android:maxLength="10"
                android:padding="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servicio"
                android:textColor="@color/azul_titulo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerServicio"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:padding="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textColor="@color/azul_titulo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtFechaCita"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:clickable="true"
                android:focusable="false"
                android:hint="Seleccione la fecha"
                android:padding="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hora"
                android:textColor="@color/azul_titulo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtHoraCita"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:clickable="true"
                android:focusable="false"
                android:hint="Seleccione la hora"
                android:padding="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Observaciones"
                android:textColor="@color/azul_titulo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtObservaciones"
                android:layout_width="match_parent"
                android:layout_height="95dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/edittext_login"
                android:gravity="top"
                android:hint="Ejemplo: desea atención en la tarde"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="Estado inicial: Pendiente"
                android:textAlignment="center"
                android:textColor="@color/azul_titulo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGuardarCita"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/boton_principal"
                android:text="Guardar cita"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVolverAgendar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/boton_principal"
                android:text="Volver"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>