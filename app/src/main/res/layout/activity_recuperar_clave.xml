<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRecuperarClave"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorRecuperarClave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- LOGO -->
        <ImageView
            android:id="@+id/imgLogoRecuperarClave"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Logo Spa TAMAR"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_spa_tamar" />

        <!-- ENCABEZADO -->
        <TextView
            android:id="@+id/txtTituloRecuperarClave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recuperar contraseña"
            android:textAlignment="center"
            android:textColor="@color/azul_oscuro_moderno"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- CARD PRINCIPAL -->
        <LinearLayout
            android:id="@+id/cardRecuperarClave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/card_moderno"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- PASO 1 -->
            <TextView
                android:id="@+id/txtPasoCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paso 1: Solicitar código"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtCorreoRecuperacion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/edittext_login"
                android:hint="Correo registrado"
                android:inputType="textEmailAddress"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSolicitarCodigo"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/boton_principal"
                android:text="Enviar código"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- DIVISOR VISUAL -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="22dp"
                android:background="@color/borde_suave_moderno" />

            <!-- PASO 2 -->
            <TextView
                android:id="@+id/txtPasoNuevaClave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paso 2: Restablecer contraseña"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDescripcionPasoNuevaClave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ingrese el código recibido y su nueva contraseña."
                android:textColor="@color/gris_moderno"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtCodigoRecuperacion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/edittext_login"
                android:hint="Código recibido"
                android:inputType="number"
                android:maxLength="6"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtNuevaClave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Nueva contraseña"
                android:inputType="textPassword"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtConfirmarNuevaClave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Confirmar contraseña"
                android:inputType="textPassword"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtAyudaNuevaClave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="La contraseña debe tener mínimo 6 caracteres, una mayúscula, un número y un carácter especial."
                android:textColor="@color/gris_moderno"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRestablecerClave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/boton_principal"
                android:text="Restablecer contraseña"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVolverRecuperarClave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/boton_secundario_moderno"
                android:text="Volver al login"
                android:textAllCaps="false"
                android:textColor="@color/azul_moderno"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtPieRecuperarClave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="18dp"
            android:text="Spa TAMAR protege el acceso de sus usuarios mediante recuperación por código."
            android:textAlignment="center"
            android:textColor="@color/gris_moderno"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>