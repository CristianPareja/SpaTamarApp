<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorAgendarCita"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ENCABEZADO -->
        <LinearLayout
            android:id="@+id/headerAgendarCita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="20dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/fondo_icono_azul"
                android:padding="12dp"
                android:src="@drawable/ic_calendar_moderno" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Agendar cita"
                    android:textColor="@color/azul_oscuro_moderno"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- INFORMACIÓN DEL CLIENTE -->
        <LinearLayout
            android:id="@+id/cardClienteAgendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_moderno_verde"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/fondo_icono_verde"
                android:padding="10dp"
                android:src="@drawable/ic_profile_moderno" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtClientePerfil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Cliente: perfil no cargado"
                    android:textColor="@color/verde_positivo"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- FORMULARIO -->
        <LinearLayout
            android:id="@+id/cardFormularioAgendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Datos de la cita"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/chkAgendarFamiliar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="Agendar cita para un familiar"
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtNombreFamiliar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del familiar"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <EditText
                android:id="@+id/edtNombreFamiliar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Ejemplo: Ana López"
                android:inputType="textPersonName"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtTelefonoCliente"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Ejemplo: 0999999999"
                android:inputType="phone"
                android:maxLength="10"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servicio"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerServicio"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:padding="10dp" />

            <!-- FECHA Y HORA EN FILA -->
            <LinearLayout
                android:id="@+id/filaFechaHoraCita"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fecha"
                        android:textColor="@color/azul_oscuro_moderno"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtFechaCita"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_login"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="Fecha"
                        android:padding="12dp"
                        android:textColor="@color/texto_oscuro_moderno"
                        android:textColorHint="@color/gris_moderno"
                        android:textSize="13sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hora"
                        android:textColor="@color/azul_oscuro_moderno"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtHoraCita"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_login"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="Hora"
                        android:padding="12dp"
                        android:textColor="@color/texto_oscuro_moderno"
                        android:textColorHint="@color/gris_moderno"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Observaciones"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtObservaciones"
                android:layout_width="match_parent"
                android:layout_height="95dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/edittext_login"
                android:gravity="top"
                android:hint="Ejemplo: desea atención en la tarde"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:maxLines="5"
                android:scrollbars="vertical"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtEstadoInicialCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/fondo_chip_moderno"
                android:paddingLeft="12dp"
                android:paddingTop="7dp"
                android:paddingRight="12dp"
                android:paddingBottom="7dp"
                android:text="Estado inicial: En curso"
                android:textColor="@color/azul_moderno"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGuardarCita"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/boton_principal"
                android:text="Agendar cita"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVolverAgendar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/boton_secundario_moderno"
                android:text="Volver"
                android:textAllCaps="false"
                android:textColor="@color/azul_moderno"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>