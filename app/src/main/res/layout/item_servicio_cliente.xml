<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/card_login"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/txtNombreServicioCliente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre del servicio"
        android:textColor="#3E2723"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtDescripcionServicioCliente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Descripción del servicio"
        android:textColor="#5D4037"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtPrecioServicioCliente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="$ 0.00"
        android:textColor="#8D6E63"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Tocar para agendar cita"
        android:textColor="#795548"
        android:textSize="13sp"
        android:textStyle="italic" />

</LinearLayout>