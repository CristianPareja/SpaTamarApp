<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainSimulacionProyeccion"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorPrincipalSimulacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ENCABEZADO -->
        <LinearLayout
            android:id="@+id/headerSimulacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="20dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/fondo_icono_morado"
                android:padding="12dp"
                android:src="@drawable/ic_simulation_moderno" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTituloSimulacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Simulación y proyección"
                    android:textColor="@color/azul_oscuro_moderno"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloSimulacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Evalúa escenarios de ingresos, egresos y cobros pendientes"
                    android:textColor="@color/gris_moderno"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- SITUACION ACTUAL -->
        <LinearLayout
            android:id="@+id/cardDatosActuales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTituloDatosActuales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Situación actual"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtIngresosActuales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ingresos actuales: $0.00"
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtEgresosActuales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Egresos actuales: $0.00"
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtCuentasPendientesActuales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Cuentas por cobrar pendientes: $0.00"
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtGananciaActual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Ganancia actual: $0.00"
                android:textColor="@color/azul_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- FORMULARIO -->
        <LinearLayout
            android:id="@+id/cardFormularioSimulacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTituloEscenario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Escenario a simular"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLabelVariacionIngresos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Variación esperada de ingresos (%)"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtVariacionIngresos"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edittext_login"
                android:hint="Ejemplo: 20 o -10"
                android:inputType="numberDecimal|numberSigned"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtLabelIncrementoEgresos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Incremento esperado de egresos (%)"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtIncrementoEgresos"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edittext_login"
                android:hint="Ejemplo: 10"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtLabelPagosAtrasados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Porcentaje de pagos pendientes atrasados (%)"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtPagosAtrasados"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edittext_login"
                android:hint="Ejemplo: 30"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCalcularSimulacion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/boton_principal"
                android:text="Calcular proyección"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLimpiarSimulacion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/boton_secundario_moderno"
                android:text="Limpiar simulación"
                android:textAllCaps="false"
                android:textColor="@color/azul_moderno"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- RESULTADO -->
        <LinearLayout
            android:id="@+id/cardResultadoSimulacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTituloResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resultado de la simulación"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtResultadoSimulacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ingrese los valores del escenario y presione calcular."
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtRiesgoSimulacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/fondo_chip_moderno"
                android:paddingLeft="12dp"
                android:paddingTop="7dp"
                android:paddingRight="12dp"
                android:paddingBottom="7dp"
                android:text="Riesgo: sin calcular"
                android:textColor="@color/azul_moderno"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ALERTAS -->
        <LinearLayout
            android:id="@+id/cardAlertasSimulacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTituloAlertasSimulacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alertas de escenario"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAlertasSimulacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Las alertas aparecerán después de calcular la simulación."
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="15sp" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverSimulacion"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/boton_secundario_moderno"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="@color/azul_moderno"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>