<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainMisCitas"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorPrincipalMisCitas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtTituloMisCitas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="Mis citas e historial"
            android:textAlignment="center"
            android:textColor="@color/azul_titulo"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSubtituloMisCitas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:text="Revise sus citas actuales y el historial de atenciones"
            android:textAlignment="center"
            android:textColor="@color/gris_texto"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtSeccionActuales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Citas actuales"
            android:textColor="@color/azul_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/txtSinCitasActuales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_login"
            android:padding="16dp"
            android:text="No tiene citas actuales registradas."
            android:textAlignment="center"
            android:textColor="@color/azul_titulo"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/contenedorCitasActuales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/txtSeccionHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Historial de citas"
            android:textColor="@color/azul_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/txtSinHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_login"
            android:padding="16dp"
            android:text="No existen citas finalizadas o canceladas."
            android:textAlignment="center"
            android:textColor="@color/azul_titulo"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/contenedorHistorialCitas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverMisCitas"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/boton_principal"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>