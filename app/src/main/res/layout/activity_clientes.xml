<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainClientes"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorPrincipalClientes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ENCABEZADO -->
        <LinearLayout
            android:id="@+id/headerClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="20dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/fondo_icono_morado"
                android:padding="12dp"
                android:src="@drawable/ic_clients_moderno" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTituloClientes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Clientes registrados"
                    android:textColor="@color/azul_oscuro_moderno"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloClientes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Consulta los clientes activos del Spa TAMAR"
                    android:textColor="@color/gris_moderno"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- RESUMEN -->
        <LinearLayout
            android:id="@+id/cardResumenClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTotalClientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total de clientes registrados: 0"
                android:textColor="@color/morado_moderno"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNotaClientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Esta sección es solo informativa. Los clientes se crean desde el registro de la aplicación."
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- LISTADO -->
        <TextView
            android:id="@+id/txtSeccionListaClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Listado de clientes"
            android:textColor="@color/azul_oscuro_moderno"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSinClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:padding="16dp"
            android:text="No existen clientes registrados."
            android:textAlignment="center"
            android:textColor="@color/azul_oscuro_moderno"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedorClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverClientes"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/boton_secundario_moderno"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="@color/azul_moderno"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>