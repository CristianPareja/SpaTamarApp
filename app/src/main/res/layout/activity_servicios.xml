<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityServicios"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_login"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTituloServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gestión de servicios"
            android:textAlignment="center"
            android:textColor="#3E2723"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/card_login"
            android:orientation="vertical"
            android:padding="18dp">

            <EditText
                android:id="@+id/edtNombreServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_login"
                android:hint="Nombre del servicio"
                android:inputType="textCapWords"
                android:padding="14dp"
                android:textColor="#3E2723"
                android:textColorHint="#8D6E63" />

            <EditText
                android:id="@+id/edtDescripcionServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Descripción del servicio"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:padding="14dp"
                android:textColor="#3E2723"
                android:textColorHint="#8D6E63" />

            <EditText
                android:id="@+id/edtPrecioServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Precio"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:textColor="#3E2723"
                android:textColorHint="#8D6E63" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGuardarServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/boton_principal"
                android:text="Guardar servicio"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLimpiarServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/boton_principal"
                android:text="Limpiar"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtTituloListaServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Servicios registrados"
            android:textColor="#3E2723"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedorServiciosAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/boton_principal"
            android:text="Volver"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>