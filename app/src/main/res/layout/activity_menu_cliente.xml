<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainCliente"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorCliente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/headerCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="14dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="135dp">

                <ImageView
                    android:id="@+id/imgLogoCliente"
                    android:layout_width="210dp"
                    android:layout_height="105dp"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="4dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo_spa_tamar_transparente"
                    android:contentDescription="Logo Spa TAMAR" />

                <TextView
                    android:id="@+id/txtCampanitaRecordatorio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/fondo_chip_moderno"
                    android:clickable="true"
                    android:focusable="true"
                    android:minWidth="54dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="8dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="8dp"
                    android:text="🔔"
                    android:textAlignment="center"
                    android:textColor="@color/azul_moderno"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtFechaCliente"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:text="--/--/----"
                    android:textColor="@color/gris_moderno"
                    android:textSize="12sp"
                    android:textStyle="normal" />

            </RelativeLayout>

        </LinearLayout>

        <!-- MENSAJE PRINCIPAL -->
        <LinearLayout
            android:id="@+id/cardBienvenidaCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno_verde"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="18dp">

            <ImageView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/fondo_icono_verde"
                android:padding="10dp"
                android:src="@drawable/ic_spa_moderno" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtSaludoCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hola, cliente"
                    android:textColor="@color/verde_positivo"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDescripcionCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Agenda tu cita y nosotros nos encargamos de tu cuidado personal."
                    android:textColor="@color/texto_oscuro_moderno"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ACCESOS RAPIDOS -->

        <!-- FILA 1 -->
        <LinearLayout
            android:id="@+id/filaAccesosClienteUno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnServiciosCliente"
                android:layout_width="0dp"
                android:layout_height="105dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_acceso_admin_moderno"
                android:drawableTop="@drawable/ic_spa_moderno"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:padding="10dp"
                android:text="Agendar cita"
                android:textAllCaps="false"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMisCitasCliente"
                android:layout_width="0dp"
                android:layout_height="105dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_acceso_admin_moderno"
                android:drawableTop="@drawable/ic_calendar_moderno"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:padding="10dp"
                android:text="Historial"
                android:textAllCaps="false"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- FILA 2 -->
        <LinearLayout
            android:id="@+id/filaAccesosClienteDos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCuentasPendientesCliente"
                android:layout_width="0dp"
                android:layout_height="105dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_acceso_admin_moderno"
                android:drawableTop="@drawable/ic_receipt_moderno"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:padding="10dp"
                android:text="Cuentas pendientes"
                android:textAllCaps="false"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPerfilCliente"
                android:layout_width="0dp"
                android:layout_height="105dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_acceso_admin_moderno"
                android:drawableTop="@drawable/ic_profile_moderno"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:padding="10dp"
                android:text="Mi perfil"
                android:textAllCaps="false"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- CERRAR SESION -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCerrarSesionCliente"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/boton_cerrar_sesion_moderno"
            android:drawableStart="@drawable/ic_logout_moderno"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:padding="10dp"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textColor="@color/rojo_negativo"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>