<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainCitasAdmin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorPrincipalCitasAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtTituloCitasAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="15dp"
            android:text="Citas del administrador"
            android:textAlignment="center"
            android:textColor="@color/azul_titulo"
            android:textSize="25sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/cardFechaCitasAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_login"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtFechaSeleccionadaAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fecha: --/--/----"
                android:textAlignment="center"
                android:textColor="@color/azul_titulo"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotalCitasFechaAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Total de citas: 0"
                android:textAlignment="center"
                android:textColor="@color/gris_texto"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/filaBotonesFechaCitas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDiaAnteriorCitas"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_principal"
                android:text="Día anterior"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDiaSiguienteCitas"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_principal"
                android:text="Día siguiente"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardBusquedaCitas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_login"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTituloBusquedaCitas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Búsqueda"
                android:textColor="@color/azul_titulo"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtBuscarClienteCitas"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Ingrese el nombre del cliente"
                android:inputType="textPersonName"
                android:padding="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBuscarClienteCitas"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/boton_principal"
                android:text="Buscar"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMostrarHoyCitas"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/boton_principal"
            android:text="Mostrar citas de hoy"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSeccionListadoCitasAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Listado de citas"
            android:textColor="@color/azul_titulo"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSinCitasAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_login"
            android:padding="16dp"
            android:text="No existen citas registradas para esta búsqueda."
            android:textAlignment="center"
            android:textColor="@color/azul_titulo"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedorCitasAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverCitasAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/boton_principal"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>