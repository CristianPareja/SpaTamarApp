<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainCuentasCobrarAdmin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorPrincipalCuentasCobrarAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ENCABEZADO -->
        <LinearLayout
            android:id="@+id/headerCuentasCobrarAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="20dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/fondo_icono_azul"
                android:padding="12dp"
                android:src="@drawable/ic_receipt_moderno" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTituloCuentasCobrarAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cuentas por cobrar"
                    android:textColor="@color/azul_oscuro_moderno"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloCuentasCobrarAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Saldos generados automáticamente por pagos parciales"
                    android:textColor="@color/gris_moderno"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- RESUMEN -->
        <LinearLayout
            android:id="@+id/cardResumenCuentasCobrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno_naranja"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTotalGeneralCobrar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total pendiente por cobrar: $0.00"
                android:textColor="@color/naranja_alerta"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtInfoCuentasCobrar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Estas cuentas se crean cuando el cliente no cancela el valor completo del servicio."
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- LISTADO -->
        <TextView
            android:id="@+id/txtListadoCuentasCobrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Listado de cuentas generadas"
            android:textColor="@color/azul_oscuro_moderno"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSinCuentasCobrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_moderno_verde"
            android:elevation="4dp"
            android:padding="16dp"
            android:text="No existen cuentas por cobrar pendientes."
            android:textAlignment="center"
            android:textColor="@color/verde_positivo"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedorCuentasCobrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverCuentasCobrar"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/boton_secundario_moderno"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="@color/azul_moderno"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>