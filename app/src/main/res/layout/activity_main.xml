<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="190dp"
            android:layout_height="190dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Logo Spa TAMAR"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_spa_tamar" />

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spa TAMAR"
            android:textColor="@color/azul_titulo"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSubtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belleza de Manos y Pies"
            android:textColor="@color/azul_secundario"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/cardLogin"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_login"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/txtInicioSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:text="Inicio de sesión"
                android:textColor="@color/azul_titulo"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtUsuario"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/edittext_login"
                android:hint="Usuario o correo"
                android:inputType="text"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto" />

            <EditText
                android:id="@+id/edtClave"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/edittext_login"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/gris_texto" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIngresar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/boton_principal"
                android:text="Ingresar"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRegistrarse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="8dp"
                android:text="¿No tienes cuenta? Regístrate"
                android:textColor="@color/azul_principal"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOlvideClave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="8dp"
                android:text="¿Olvidaste tu contraseña? Recupérala"
                android:textColor="@color/azul_secundario"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>