<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardServicioCliente"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/card_moderno"
    android:clickable="true"
    android:elevation="4dp"
    android:focusable="true"
    android:orientation="horizontal"
    android:padding="18dp">

    <ImageView
        android:id="@+id/imgIconoServicioCliente"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/fondo_icono_azul"
        android:padding="13dp"
        android:src="@drawable/ic_spa_moderno" />

    <LinearLayout
        android:id="@+id/contenidoServicioCliente"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombreServicioCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del servicio"
            android:textColor="@color/azul_oscuro_moderno"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescripcionServicioCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Descripción del servicio"
            android:textColor="@color/gris_moderno"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtPrecioServicioCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/fondo_chip_moderno"
            android:paddingLeft="12dp"
            android:paddingTop="6dp"
            android:paddingRight="12dp"
            android:paddingBottom="6dp"
            android:text="$0.00"
            android:textColor="@color/verde_positivo"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAccionServicioCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tocar para agendar"
            android:textColor="@color/azul_moderno"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>