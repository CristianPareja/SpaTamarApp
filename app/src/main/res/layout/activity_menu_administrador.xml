<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainAdministrador"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorAdministrador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/headerAdministrador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="14dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="135dp">

                <ImageView
                    android:id="@+id/imgLogoAdmin"
                    android:layout_width="210dp"
                    android:layout_height="105dp"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="4dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo_spa_tamar_transparente"
                    android:contentDescription="Logo Spa TAMAR" />

                <TextView
                    android:id="@+id/txtCampanitaAdmin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/fondo_chip_moderno"
                    android:clickable="true"
                    android:focusable="true"
                    android:minWidth="54dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="8dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="8dp"
                    android:text="🔔"
                    android:textAlignment="center"
                    android:textColor="@color/azul_moderno"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtFechaDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:text="--/--/----"
                    android:textColor="@color/gris_moderno"
                    android:textSize="12sp"
                    android:textStyle="normal" />

            </RelativeLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardCitasHoyDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_moderno"
            android:clickable="true"
            android:elevation="4dp"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Citas pendientes de hoy"
                android:textColor="@color/gris_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtCitasHoyDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0"
                android:textColor="@color/azul_moderno"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ver agenda del día"
                android:textColor="@color/azul_moderno"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/filaResumenFinancieroClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/cardTotalCobroDashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/card_moderno"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total por cobrar"
                    android:textColor="@color/gris_moderno"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtTotalCobroDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="$0.00"
                    android:textColor="@color/verde_positivo"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver saldos"
                    android:textColor="@color/azul_moderno"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardClientesDashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/card_moderno"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Clientes registrados"
                    android:textColor="@color/gris_moderno"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtTotalClientesDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0"
                    android:textColor="@color/morado_moderno"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver clientes"
                    android:textColor="@color/azul_moderno"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardGananciasDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ganancia neta"
                android:textColor="@color/gris_moderno"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/filaSelectorMesDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="3">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMesAnteriorDashboard"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="0.7"
                    android:background="@drawable/boton_secundario_moderno"
                    android:text="←"
                    android:textAllCaps="false"
                    android:textColor="@color/azul_moderno"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtMesResumenDashboard"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1.6"
                    android:background="@drawable/fondo_chip_moderno"
                    android:gravity="center"
                    android:text="Julio 2026"
                    android:textColor="@color/azul_moderno"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMesSiguienteDashboard"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="0.7"
                    android:background="@drawable/boton_secundario_moderno"
                    android:text="→"
                    android:textAllCaps="false"
                    android:textColor="@color/azul_moderno"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtGananciaNetaDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="$0.00"
                android:textColor="@color/azul_titulo"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDetalleFinancieroDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ingresos: $0.00 | Egresos: $0.00"
                android:textColor="@color/gris_moderno"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardEstadoFinanciero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_moderno_verde"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtEstadoFinanciero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Flujo saludable"
                android:textColor="@color/verde_positivo"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMensajeEstadoFinanciero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="El negocio mantiene una ganancia positiva."
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardEstadisticasServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estadísticas de servicios"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtServicioMasUtilizado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Más utilizado: Sin datos"
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtServicioMenosUtilizado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Menos utilizado: Sin datos"
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTituloGraficoPastel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Distribución de ingresos por servicio"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.puce.spatamar.GraficoPastelServiciosView
                android:id="@+id/graficoPastelServicios"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/filaAccesosAdministrativos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnServiciosAdmin"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_acceso_admin_moderno"
                android:drawableTop="@drawable/ic_spa_moderno"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="Servicios"
                android:textAllCaps="false"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCuentasPagarAdmin"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_acceso_admin_moderno"
                android:drawableTop="@drawable/ic_receipt_moderno"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="Cuentas por pagar"
                android:textAllCaps="false"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="11sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSimulacionProyeccionAdmin"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/boton_acceso_admin_moderno"
                android:drawableTop="@drawable/ic_simulation_moderno"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="Simulación"
                android:textAllCaps="false"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCerrarSesionAdmin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/boton_cerrar_sesion_moderno"
            android:drawableStart="@drawable/ic_logout_moderno"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:padding="10dp"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textColor="@color/rojo_negativo"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>