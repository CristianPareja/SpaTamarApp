<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainCuentasPagarAdmin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_moderno_spa"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorPrincipalCuentasPagarAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ENCABEZADO -->
        <LinearLayout
            android:id="@+id/headerCuentasPagarAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="20dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/fondo_icono_azul"
                android:padding="12dp"
                android:src="@drawable/ic_receipt_moderno" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTituloCuentasPagarAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cuentas por pagar"
                    android:textColor="@color/azul_oscuro_moderno"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloCuentasPagarAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Registra y controla los egresos del Spa TAMAR"
                    android:textColor="@color/gris_moderno"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- FORMULARIO -->
        <LinearLayout
            android:id="@+id/cardFormularioCuentaPagar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registrar egreso"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerTipoEgreso"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:padding="10dp" />

            <EditText
                android:id="@+id/edtFechaPagar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:clickable="true"
                android:focusable="false"
                android:hint="Fecha del egreso"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtValorPagar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:hint="Valor a pagar"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtObservacionPagar"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_login"
                android:gravity="top"
                android:hint="Observación"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="@color/texto_oscuro_moderno"
                android:textColorHint="@color/gris_moderno"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/chkEgresoRecurrente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="Repetir mensualmente"
                android:textColor="@color/azul_oscuro_moderno"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegistrarCuentaPagar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/boton_principal"
                android:text="Registrar egreso"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- RESUMEN -->
        <LinearLayout
            android:id="@+id/cardResumenCuentasPagar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_moderno_rojo"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtTotalCuentasPagar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total egresos registrados: $0.00"
                android:textColor="@color/rojo_negativo"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNotaCuentasPagar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Los egresos registrados se descuentan automáticamente de la ganancia neta del dashboard."
                android:textColor="@color/texto_oscuro_moderno"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- LISTADO -->
        <TextView
            android:id="@+id/txtListadoCuentasPagar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Listado de egresos registrados"
            android:textColor="@color/azul_oscuro_moderno"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSinCuentasPagar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_moderno_verde"
            android:elevation="4dp"
            android:padding="16dp"
            android:text="No existen egresos registrados."
            android:textAlignment="center"
            android:textColor="@color/verde_positivo"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedorCuentasPagar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverCuentasPagar"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/boton_secundario_moderno"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="@color/azul_moderno"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>